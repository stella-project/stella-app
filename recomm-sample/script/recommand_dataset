import json
from flask import jsonify, request, Flask
import pickle
import os
import sys
import ast

app = Flask(__name__)
import pandas as pd 
import sys 
import json
import pickle
import os


f = pickle.load(open("cosine_similarity_matrix_top_10.pkl", "rb"))
def getsimilarityjson(id):
    try:
        a= {"response_header":{
           "status":0,
           "q_time":0,
           "container":"recomm-sample",
           "ts":"1580380932371",
           "params":{
           "q":"",
           "page":0,
           "results_per_page":0,
           "sid":"0",
           "rid":"0"
           }
           }}
        a.update([sim for sim in f if sim["target_items"]==id][0])
        a['similar_items']=[{"id":k, "detail":{"score": v,"reason":"" }} for k, v in a['similar_items'].items()] 
        return a 
    except:
        return None
        
@app.route('/api/recomm-sample/')
def hello_world():
   return('Hello recomm-sample')

@app.route('/api/recomm-sample/<string:id>', methods=['GET'])
def home(id):
    sim = getsimilarityjson(id)
    return(jsonify(sim))

if __name__ == '__main__':
   app.run(host='0.0.0.0', port=8889 , debug = True)



