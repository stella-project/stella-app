similarity_all=[]
for idf in pubdf.index:
    try:
        similarity_all.append({"target_items":idf,"similar_items":getSimilarDataset(idf)})
    except:
        print(idf)
    
with open('DocVec_similarity_matrix_top_10.pkl', 'wb') as b:
