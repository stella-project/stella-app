#!/usr/bin/env python3
import json
from flask import jsonify, request, Flask
import pickle
import os
import sys
from Similar import Similar
import ast

app = Flask(__name__)

similarity_all_eval = Similar.get_similarity_matrix_top_10()


def getsimilarityjson(id):
    try:
        a= {"response_header":{
           "status":0,
           "q_time":0,
           "container":"recomm_new",
           "ts":"1580380932371",
           "params":{
           "q":"",
           "page":0,
           "results_per_page":0,
           "sid":"0",
           "rid":"0"
        }
        }}
        a.update( [sim for sim in similarity_all_eval if sim['target_items']==id][0])
        a['similar_items'] = [{"id":item[0], "detail":{"score": item[1],"reason":"" }} for item in a['similar_items']]
        return a
    except:
        return None

@app.route('/api/recomm_new/')
def hello_world():
   return('Hello recomm_new')

@app.route('/api/recomm_new/<string:id>', methods=['GET'])
def home(id):
    sim = getsimilarityjson(id)
    return(jsonify(sim))

if __name__ == '__main__':
   app.run(host='0.0.0.0', port=8888 , debug = True)


                 
